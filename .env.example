# =============================================================================
# RentAdria — kopiraj u .env.local (lokalno, gitignored). Na Vercelu: iste
# vrijednosti u Project → Settings → Environment Variables.
#
# VAŽNO — ovo je Vite + React projekat (NE Next.js):
#   Nemoj koristiti NEXT_PUBLIC_*, NextAuth, Stripe, Cloudinary iz drugog tutora
#   ili starog Vercel projekta — to nije ovaj repo. Ako Vercel projekat već ima
#   samo te varijable, ili si povezao pogrešan GitHub repo, ili je ostao stari
#   projekat: napravi NOVI Vercel projekat iz repoa rentadria (Vite) ili obriši
#   pogrešne varijable i dodaj ispod navedene.
#
# Vite u klijentski bundle ugrađuje SAMO varijable koje počinju sa VITE_.
# Lozinke i server tajne NIKAD u VITE_*.
# =============================================================================

# --- Admin panel (/api/admin-auth) — SAMO server (bez VITE_) ---
# Za lokalni rad: kopiraj ove vrijednosti u `.env.local` (gitignored, ne ide na push).
ADMIN_EMAIL=info@rentadria.com
ADMIN_PASSWORD=
# Min. 32 znaka — potpis JWT session kolačića (na Vercelu obavezno; u `npm run dev` ima dev fallback)
ADMIN_SESSION_SECRET=

# --- Samo lokalni dev: automatski vlasnički nalog u browseru (localStorage) ---
# NE postavljati na Vercelu. Zahtijeva `npm run dev` i ispravne VITE_* ispod.
# VITE_LOCAL_OWNER_SEED=1
# VITE_LOCAL_OWNER_EMAIL=tvoj@email.com
# VITE_LOCAL_OWNER_PASSWORD=

# --- Email (Brevo / Sendinblue) — transakcijski mail (verifikacija, upiti, itd.) ---
# https://www.brevo.com — API key u Dashboard → SMTP & API → API keys
BREVO_API_KEY=
BREVO_SENDER_EMAIL=info@rentadria.com
# BREVO_SENDER_NAME=RentAdria
# Alternativa SMTP: BREVO_SMTP_USER, BREVO_SMTP_PASS, BREVO_SMTP_HOST, BREVO_SMTP_PORT

# --- JWT (verifikacija emaila / tokeni) — server, min. 16 znakova u produkciji ---
JWT_SECRET=

# --- Javni URL sajta (linkovi u mailovima, social) ---
# Na Vercelu često dovoljno postaviti ručno; inače koristi VERCEL_URL u kodu gdje je podržano
SITE_URL=https://tvoj-domen.com

# --- Supabase (opciono) — ako koristiš bazu / storage ---
# U browseru (RLS): samo ove dvije sa VITE_
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server (service role) — nikad u frontend; samo Vercel env
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# Nakon povezivanja: u SQL Editor pokreni i migracije za promo (002) i vlasnike (004_registered_owners.sql)
# da admin „Vlasnici“ i prijava vlasnika s drugog uređaja rade preko servera.
# Supabase bucket za slike social reda (default: social-render)
# SUPABASE_SOCIAL_BUCKET=social-render

# --- Instagram / Facebook (Meta Graph API) — objave iz reda (cron) ---
# META_IG_USER_ID=
# META_ACCESS_TOKEN=
# META_PAGE_ID=
# META_PAGE_ACCESS_TOKEN=   # ako imaš poseban page token
# META_GRAPH_VERSION=v21.0

# --- Red za social objave (enqueue iz fronta) ---
# Server:
# SOCIAL_ENQUEUE_SECRET=
# Isti string u buildu (zaštita poziva):
# VITE_SOCIAL_ENQUEUE_SECRET=

# --- Statistika posjeta (admin) ---
# SITE_VISITS_READ_SECRET=
# VITE_SITE_VISITS_READ_SECRET=

# --- Admin sync stub (ako koristiš) ---
# ADMIN_SYNC_SECRET=
# VITE_ADMIN_SYNC_SECRET=

# --- Cron za /api/social-process-queue (Vercel cron) ---
# CRON_SECRET=

# --- Promotivni kodovi (Vercel + GitHub deploy) ---
# 1) Preporučeno: Supabase — pokreni SQL iz supabase/migrations/002_promo_codes.sql, zatim na Vercelu:
#    SUPABASE_URL=  i  SUPABASE_SERVICE_ROLE_KEY=  (isti projekat kao VITE_SUPABASE_*).
#    Admin → Promo sinhronizuje kodove u bazu; vlasnici rješavaju kod preko /api/promo-resolve i /api/promo-redeem.
# 2) Fallback bez migracije: kopiraj JSON iz admina u env (za hitno testiranje):
# RENTADRIA_ADMIN_PROMO_JSON=[{"id":"...","code":"ABC",...}]

# --- GitHub Pages build (samo ako gradiš sa VITE_BASE_PATH=/rentadria/) ---
# VITE_BASE_PATH=
