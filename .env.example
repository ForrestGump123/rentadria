# Copy to `.env.local` (gitignored). Vite exposes only variables prefixed with VITE_ to the client.
# Do NOT put admin or owner passwords in VITE_* — they would appear in the public JS bundle.

# --- Admin login (server-only; used by /api/admin-auth and Vite dev middleware) ---
# On Vercel: set these in Project → Settings → Environment Variables (not VITE_).
ADMIN_EMAIL=info@rentadria.com
ADMIN_PASSWORD=
# Min. 32 characters; used to sign the admin session cookie (JWT).
ADMIN_SESSION_SECRET=

# --- Local dev (optional) — owner test accounts: register via the site UI, or use a local script. ---

# --- Supabase (https://supabase.com) — Postgres, Auth, Storage kada povežete produkciju ---
# Project Settings → API: Project URL i anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Čitanje statistike posjeta (API na Vercelu) ---
# VITE_SITE_VISITS_READ_SECRET=

# --- Ostalo (backend / serverless na Vercelu, ne stavljati tajne u VITE_) ---
# Primjer: Brevo (https://www.brevo.com) za transakcijski email — API ključ samo u Vercel Environment Variables,
# nije u frontendu. Npr. BREVO_API_KEY, BREVO_SENDER_EMAIL=info@rentadria.com
