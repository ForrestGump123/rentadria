# OBAVEZNO na Vercelu (Settings → Environment Variables)
# Nikad ne commituj prave vrijednosti.

# Potpis linka u emailu (min. 16 znakova, nasumičan string)
JWT_SECRET=

# Javni URL sajta (link u emailu za potvrdu)
SITE_URL=https://tvoj-projekat.vercel.app

# Brevo — opcija A: REST API (API key iz Brevo → SMTP & API → API keys, često xkeysib-…)
BREVO_API_KEY=

# Brevo — opcija B: SMTP (ako koristiš xsmtpsib-… kao SMTP lozinku)
# Login vidiš u Brevo → SMTP & API → SMTP (obično email ili smtp korisnik)
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# Pošiljalac (mora biti potvrđen u Brevu)
BREVO_SENDER_EMAIL=info@rentadria.com
BREVO_SENDER_NAME=RentAdria
