# --- Vercel / production (copy to Project → Environment Variables) ---
# Same value in all environments where you send AND verify email (min 16 characters).
JWT_SECRET=

# Public site URL used in verification emails (include https, no trailing slash).
# Example: https://rentadrianovi.vercel.app
SITE_URL=

# Brevo (send transactional email): REST API key OR SMTP
BREVO_API_KEY=
# BREVO_SMTP_USER=
# BREVO_SMTP_PASS=

# Optional: admin panel password (see VITE_ADMIN_PASSWORD in frontend)
