# OBAVEZNO na Vercelu (Settings → Environment Variables)
# Nikad ne commituj prave vrijednosti.

# Potpis linka u emailu (min. 16 znakova, nasumičan string)
JWT_SECRET=

# Javni URL sajta (link u emailu za potvrdu)
SITE_URL=https://tvoj-projekat.vercel.app

# Brevo — opcija A: REST API (API key iz Brevo → SMTP & API → API keys, često xkeysib-…)
BREVO_API_KEY=

# Brevo — opcija B: SMTP (ako koristiš xsmtpsib-… kao SMTP lozinku)
# Login vidiš u Brevo → SMTP & API → SMTP (obično email ili smtp korisnik)
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# Pošiljalac (mora biti potvrđen u Brevu)
BREVO_SENDER_EMAIL=info@rentadria.com
BREVO_SENDER_NAME=RentAdria

# Supabase (SQL + bucket vidi supabase/migrations/001_social_queue.sql)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Javni bucket za renderovane slike (Dashboard → Storage → public)
SUPABASE_SOCIAL_BUCKET=social-render

# Istu vrijednost kao ispod, u Vite (samo za build) — za slanje u red sa fronta
VITE_SOCIAL_ENQUEUE_SECRET=
# Tajni string za /api/social-enqueue (mora se poklapati s VITE_SOCIAL_ENQUEUE_SECRET)
SOCIAL_ENQUEUE_SECRET=

# Meta / Instagram / Facebook (Graph API)
META_GRAPH_VERSION=v21.0
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=

# Opcionalno: ručno pokretanje reda (ako nije Vercel cron)
CRON_SECRET=

# Javni URL sajta (caption linkovi) — obično isti kao SITE_URL za email
SITE_URL=https://rentadria.com

# Statistika posjeta (admin) — ako postaviš, mora isti kao VITE_* ispod
SITE_VISITS_READ_SECRET=
# Isti kao SITE_VISITS_READ_SECRET (Vite ugrađuje u build — i dalje ograniči ko vidi admin)
VITE_SITE_VISITS_READ_SECRET=

# Admin sinhronizacija (API) — isti string na serveru i u Vite
ADMIN_SYNC_SECRET=
VITE_ADMIN_SYNC_SECRET=
